{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MedicationLabelTrainingData",
  "description": "Training data schema for GoldLabel medication label OCR model. Each entry maps raw OCR text to a set of pictogram actions across 6 categories. Pictograms are language-specific images with text embedded — no separate label field. One pictogram per action per language.",
  "type": "object",
  "required": [
    "raw_ocr_reference",
    "medication_name",
    "language",
    "pictogram_categories"
  ],
  "properties": {
    "raw_ocr_reference": {
      "type": "string",
      "description": "The original OCR text from GCP Cloud Vision used to train the model."
    },
    "medication_name": {
      "type": "string",
      "description": "The extracted name of the medicine."
    },
    "language": {
      "type": "string",
      "description": "Language code indicating which language variant of the pictograms to use. Use 'none' for pictogram-only labels with no embedded text. The remaining 12 codes are ISO 639-1 language codes.",
      "enum": ["none", "en", "bn", "hi", "kn", "ml", "te", "my", "th", "vi", "zh", "ms", "ta"],
      "enumDescriptions": {
        "none": "No text — pictogram only",
        "en": "English",
        "bn": "Bengali (বাংলা)",
        "hi": "Hindi (हिन्दी)",
        "kn": "Kannada (ಕನ್ನಡ)",
        "ml": "Malayalam (മലയാളം)",
        "te": "Telugu (తెలుగు)",
        "my": "Burmese (မြန်မာဘာသာ)",
        "th": "Thai (ภาษาไทย)",
        "vi": "Vietnamese (Tiếng Việt)",
        "zh": "Chinese (中文)",
        "ms": "Malay (Bahasa Melayu)",
        "ta": "Tamil (தமிழ்)"
      }
    },
    "pictogram_categories": {
      "type": "object",
      "description": "Each property maps to a pictogram category. The value is a pictogram_id string referencing a specific action image in the database, or null if the category is not applicable for this medication.",
      "required": [
        "how_to_take",
        "side_effects",
        "duration",
        "dosage",
        "time_of_day",
        "precautions"
      ],
      "properties": {
        "how_to_take": {
          "type": ["string", "null"],
          "description": "Pictogram ID for how the medication should be taken (e.g. swallow whole, dissolve in water, take with food). 8 unique pictograms per language; 104 total across 13 languages.",
          "examples": [
            "how_to_take.swallow_whole",
            "how_to_take.dissolve_in_water",
            "how_to_take.with_food",
            "how_to_take.with_water",
            "how_to_take.empty_stomach",
            "how_to_take.take_30_min_before_food",
            "how_to_take.take_30_min_after_food"
          ]
        },
        "how_to_take_variant": {
          "type": ["string", "null"],
          "description": "Optional variant identifier for how_to_take, used only when a pictogram has more than one art version (e.g. 'how_to_take.dissolve_in_water' has v1=powder/sachet and v2=tablet/effervescent). Omit or set to null when how_to_take has no variants. Database default is 'v0'.",
          "examples": ["v1", "v2"]
        },
        "side_effects": {
          "type": ["string", "null"],
          "description": "Pictogram ID for a notable side effect of the medication. 17 unique pictograms per language; 221 total across 13 languages.",
          "examples": [
            "side_effects.drowsiness",
            "side_effects.dizziness",
            "side_effects.headache",
            "side_effects.blurred_vision",
            "side_effects.tremors",
            "side_effects.nausea",
            "side_effects.vomiting",
            "side_effects.diarrhea",
            "side_effects.constipation",
            "side_effects.dry_mouth",
            "side_effects.light_sensitivity",
            "side_effects.allergic_reaction",
            "side_effects.muscle_weakness",
            "side_effects.fast_heartbeat",
            "side_effects.fever",
            "side_effects.fall_risk",
            "side_effects.do_not_drive"
          ]
        },
        "duration": {
          "type": ["string", "null"],
          "description": "Pictogram ID for how long the medication course should last. 36 unique pictograms per language; 468 total across 13 languages.",
          "examples": [
            "duration.take_1_day",
            "duration.take_3_days",
            "duration.take_5_days",
            "duration.take_7_days",
            "duration.take_10_days",
            "duration.take_1_week",
            "duration.take_4_weeks",
            "duration.take_10_weeks",
            "duration.take_1_month",
            "duration.take_3_months",
            "duration.take_6_months",
            "duration.take_12_months",
            "duration.complete_course",
            "duration.stop_only_on_doctors_advice",
            "duration.until_symptoms_resolve",
            "duration.repeat_cycle"
          ]
        },
        "dosage": {
          "type": ["string", "null"],
          "description": "Pictogram ID for the dose amount (e.g. 1 tablet, 2 ear drops, 1 teaspoon, 5ml injection). 27 unique pictograms per language; 351 total across 13 languages.",
          "examples": [
            "dosage.tablet_half",
            "dosage.tablet_1",
            "dosage.tablet_1_5",
            "dosage.tablet_2",
            "dosage.tablet_2_5",
            "dosage.tablet_3",
            "dosage.tablet_3_5",
            "dosage.tablet_4",
            "dosage.tablet_4_5",
            "dosage.teaspoon_1",
            "dosage.teaspoon_2",
            "dosage.teaspoon_3",
            "dosage.tablespoon_1",
            "dosage.tablespoon_2",
            "dosage.tablespoon_3",
            "dosage.ear_drop_1",
            "dosage.ear_drop_2",
            "dosage.ear_drop_3",
            "dosage.ear_drop_4",
            "dosage.eye_drop_1",
            "dosage.eye_drop_2",
            "dosage.eye_drop_3",
            "dosage.eye_drop_4",
            "dosage.ml_5",
            "dosage.ml_10",
            "dosage.ml_15",
            "dosage.ml_20"
          ]
        },
        "time_of_day": {
          "type": ["string", "null"],
          "description": "Pictogram ID for when and how often the medication should be taken (time of day, meal, or dose frequency). 13 unique pictograms per language; 169 total across 13 languages.",
          "examples": [
            "time_of_day.once_daily",
            "time_of_day.twice_daily",
            "time_of_day.thrice_daily",
            "time_of_day.morning",
            "time_of_day.noon",
            "time_of_day.night",
            "time_of_day.upon_waking",
            "time_of_day.before_bed",
            "time_of_day.every_4_hours",
            "time_of_day.every_8_hours",
            "time_of_day.with_breakfast",
            "time_of_day.with_lunch",
            "time_of_day.with_dinner"
          ]
        },
        "precautions": {
          "type": ["string", "null"],
          "description": "Pictogram ID for special precautions or warnings (e.g. avoid alcohol, keep refrigerated, keep away from children). 17 unique pictograms per language; 221 total across 13 languages.",
          "examples": [
            "precautions.no_alcohol",
            "precautions.no_dairy",
            "precautions.no_grapefruit",
            "precautions.keep_refrigerated",
            "precautions.keep_refrigerated_no_freeze",
            "precautions.keep_away_from_light",
            "precautions.keep_away_from_children",
            "precautions.keep_away_from_pets",
            "precautions.dispose_properly",
            "precautions.do_not_share",
            "precautions.not_if_pregnant",
            "precautions.not_if_breastfeeding",
            "precautions.consult_doctor_before_taking",
            "precautions.consult_doctor_if_symptoms_worsen",
            "precautions.check_expiry_date",
            "precautions.discard_8_weeks_after_opening",
            "precautions.store_cool_dry_place"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "raw_ocr_reference": "Metformin 500mg. Take 1 tablet twice daily with food. May cause nausea. Take for 30 days.",
      "medication_name": "Metformin 500mg",
      "language": "en",
      "pictogram_categories": {
        "how_to_take": "how_to_take_take.with_food",
        "side_effects": "side_effects.nausea",
        "duration": "duration.take_1_month",
        "dosage": "dosage.tablet_1",
        "time_of_day": "time_of_day.twice_daily",
        "precautions": null
      }
    }
  ]
}
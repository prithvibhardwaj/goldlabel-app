{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MedicationLabelTrainingData",
  "description": "Training data schema for GoldLabel medication label OCR model. Each entry maps raw OCR text to a set of pictogram actions across 6 categories. Pictograms are language-specific images with text embedded — no separate label field. One pictogram per action per language.",
  "type": "object",
  "required": [
    "raw_ocr_reference",
    "medication_name",
    "language",
    "pictogram_categories"
  ],
  "properties": {
    "raw_ocr_reference": {
      "type": "string",
      "description": "The original OCR text from GCP Cloud Vision used to train the model."
    },
    "medication_name": {
      "type": "string",
      "description": "The extracted name of the medicine."
    },
    "language": {
      "type": "string",
      "description": "Language code indicating which language variant of the pictograms to use. Use 'none' for pictogram-only labels with no embedded text. The remaining 12 codes are ISO 639-1 language codes.",
      "enum": ["none", "en", "bn", "hi", "kn", "ml", "te", "my", "th", "vi", "zh", "ms", "ta"],
      "enumDescriptions": {
        "none": "No text — pictogram only",
        "en": "English",
        "bn": "Bengali (বাংলা)",
        "hi": "Hindi (हिन्दी)",
        "kn": "Kannada (ಕನ್ನಡ)",
        "ml": "Malayalam (മലയാളം)",
        "te": "Telugu (తెలుగు)",
        "my": "Burmese (မြန်မာဘာသာ)",
        "th": "Thai (ภาษาไทย)",
        "vi": "Vietnamese (Tiếng Việt)",
        "zh": "Chinese (中文)",
        "ms": "Malay (Bahasa Melayu)",
        "ta": "Tamil (தமிழ்)"
      }
    },
    "pictogram_categories": {
      "type": "object",
      "description": "Each property maps to a pictogram category. The value is a pictogram_id string referencing a specific action image in the database, or null if the category is not applicable for this medication.",
      "required": [
        "how_to_take",
        "side_effects",
        "duration",
        "dosage",
        "time_of_day",
        "precautions"
      ],
      "properties": {
        "how_to_take": {
          "type": ["string", "null"],
          "description": "Pictogram ID for how the medication should be taken (e.g. swallow whole, dissolve in water, take with food). 8 unique pictograms per language; 104 total across 13 languages.",
          "examples": [
            "how_to_take_swallow_whole",
            "how_to_take_dissolve_in_water",
            "how_to_take_take_with_food",
            "how_to_take_take_with_water",
            "how_to_take_take_on_empty_stomach",
            "how_to_take_take_30min_before_food",
            "how_to_take_take_30min_after_food"
          ]
        },
        "side_effects": {
          "type": ["string", "null"],
          "description": "Pictogram ID for a notable side effect of the medication. 17 unique pictograms per language; 221 total across 13 languages.",
          "examples": [
            "side_effects_may_cause_drowsiness",
            "side_effects_may_cause_dizziness",
            "side_effects_avoid_driving"
          ]
        },
        "duration": {
          "type": ["string", "null"],
          "description": "Pictogram ID for how long the medication course should last. 36 unique pictograms per language; 468 total across 13 languages.",
          "examples": [
            "duration_1_day",
            "duration_3_days",
            "duration_5_days",
            "duration_7_days",
            "duration_10_days",
            "duration_1_week",
            "duration_4_weeks",
            "duration_10_weeks",
            "duration_1_month",
            "duration_3_months",
            "duration_6_months",
            "duration_12_months",
            "duration_complete_course",
            "duration_stop_on_doctors_advice",
            "duration_take_until_symptoms_resolve",
            "duration_repeat_cycle"
          ]
        },
        "dosage": {
          "type": ["string", "null"],
          "description": "Pictogram ID for the dose amount (e.g. 1 tablet, 2 ear drops, 1 teaspoon, 5ml injection). 27 unique pictograms per language; 351 total across 13 languages.",
          "examples": [
            "dosage_half_tablet",
            "dosage_1_tablet",
            "dosage_1_and_half_tablets",
            "dosage_2_tablets",
            "dosage_3_tablets",
            "dosage_4_tablets",
            "dosage_4_and_half_tablets",
            "dosage_1_teaspoon",
            "dosage_2_teaspoons",
            "dosage_3_teaspoons",
            "dosage_1_tablespoon",
            "dosage_2_tablespoons",
            "dosage_3_tablespoons",
            "dosage_1_ear_drop",
            "dosage_2_ear_drops",
            "dosage_3_ear_drops",
            "dosage_4_ear_drops",
            "dosage_1_eye_drop",
            "dosage_2_eye_drops",
            "dosage_3_eye_drops",
            "dosage_4_eye_drops",
            "dosage_injection_5ml",
            "dosage_injection_10ml",
            "dosage_injection_15ml",
            "dosage_injection_20ml"
          ]
        },
        "time_of_day": {
          "type": ["string", "null"],
          "description": "Pictogram ID for when and how often the medication should be taken (time of day, meal, or dose frequency). 13 unique pictograms per language; 169 total across 13 languages.",
          "examples": [
            "time_of_day_once_daily",
            "time_of_day_twice_daily",
            "time_of_day_thrice_daily",
            "time_of_day_morning",
            "time_of_day_noon",
            "time_of_day_night",
            "time_of_day_upon_waking_up",
            "time_of_day_before_bed",
            "time_of_day_every_4_hours",
            "time_of_day_every_8_hours",
            "time_of_day_with_breakfast",
            "time_of_day_with_lunch",
            "time_of_day_with_dinner"
          ]
        },
        "precautions": {
          "type": ["string", "null"],
          "description": "Pictogram ID for special precautions or warnings (e.g. avoid alcohol, keep refrigerated, keep away from children). 17 unique pictograms per language; 221 total across 13 languages.",
          "examples": [
            "precautions_avoid_alcohol",
            "precautions_avoid_dairy",
            "precautions_avoid_grapefruit",
            "precautions_keep_refrigerated",
            "precautions_keep_refrigerated_do_not_freeze",
            "precautions_keep_away_from_light",
            "precautions_keep_away_from_children",
            "precautions_keep_away_from_pets",
            "precautions_dispose_properly",
            "precautions_do_not_share",
            "precautions_do_not_take_if_pregnant",
            "precautions_do_not_take_if_breastfeeding",
            "precautions_consult_doctor_before_taking",
            "precautions_consult_doctor_if_symptoms_worsen",
            "precautions_check_expiry_date",
            "precautions_discard_8_weeks_after_opening",
            "precautions_store_in_cool_dry_place"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "raw_ocr_reference": "Metformin 500mg. Take 1 tablet twice daily with food. May cause nausea. Take for 30 days.",
      "medication_name": "Metformin 500mg",
      "language": "en",
      "pictogram_categories": {
        "how_to_take": "how_to_take_take_with_food",
        "side_effects": "side_effects_may_cause_nausea",
        "duration": "duration_1_month",
        "dosage": "dosage_1_tablet",
        "time_of_day": "time_of_day_twice_daily",
        "precautions": null
      }
    }
  ]
}

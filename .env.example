# --- Client (EXPO_PUBLIC_*): bundled into the app bundle. Non-secret values only. ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=
EXPO_PUBLIC_BACKEND_URL=

# --- Backend only: secrets. NEVER prefix with EXPO_PUBLIC_. Set these on the host
# (e.g. Railway), not in a committed file. ---
GEMINI_API_KEY=
GOOGLE_CLOUD_VISION_API_KEY=

{
  "expo": {
    "name": "GoldLabel",
    "slug": "goldlabel",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "goldlabel",
    "newArchEnabled": false,
    "ios": {
      "bundleIdentifier": "com.goldlabel.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.goldlabel.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GoldLabel to access your photos to scan medication labels.",
          "cameraPermission": "Allow GoldLabel to access your camera to scan medication labels."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GoldLabel to access your camera to scan medication labels."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "6688f225-fb9e-4c25-b715-88abdfcf2733"
      }
    }
  }
}
